<mujoco model="yam_pro_scene">
  <compiler angle="radian" meshdir="assets"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0.1 0.1 0.1"/>
    <global offwidth="1280" offheight="960"/>
  </visual>

  <asset>
    <!-- Robot meshes -->
    <mesh name="base" file="base.stl"/>
    <mesh name="link1" file="link1.stl"/>
    <mesh name="link2" file="link2.stl"/>
    <mesh name="link3" file="link3.stl"/>
    <mesh name="link4" file="link4.stl"/>
    <mesh name="link5" file="link5.stl"/>
    <mesh name="gripper_mesh" file="gripper.stl"/>
    <mesh name="tip_left" file="tip_left.stl"/>
    <mesh name="tip_right" file="tip_right.stl"/>
    <!-- Scene materials -->
    <texture type="2d" name="floor_tex" builtin="checker" width="512" height="512"
             rgb1="0.85 0.85 0.85" rgb2="0.7 0.7 0.7"/>
    <material name="floor_mat" texture="floor_tex" texrepeat="4 4" reflectance="0.1"/>
    <material name="table_mat" rgba="0.6 0.55 0.45 1"/>
  </asset>

  <worldbody>
    <!-- Lights -->
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    <light pos="0.5 0.5 1.2" dir="-0.3 -0.3 -1" diffuse="0.4 0.4 0.4"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="1 1 0.1" pos="0 0 0" material="floor_mat"/>

    <!-- Table (robot is mounted on it) -->
    <geom name="table" type="box" size="1.5 1.5 0.01" pos="0 0 0.065" material="table_mat"/>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- YAM Pro robot — mounted on table at z=0.075               -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <body name="robot_base" pos="0 0 0.075">
      <geom pos="-0.0374966 -0.0464005 0.187501" quat="0.707105 0 0.707108 0"
            type="mesh" rgba="0.317647 0.121569 0.498039 1" mesh="base" contype="0" conaffinity="0"/>

      <body name="link1" pos="0 0 0.067" quat="0.707105 0 0 -0.707108">
        <inertial pos="-0.00261782 0.00744082 0.0237251"
                  quat="0.602276 0.365837 0.642523 0.300984"
                  mass="0.104154" diaginertia="0.000139023 0.000109628 4.8478e-05"/>
        <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-2.61799 3.05433"/>
        <geom pos="-0.0464 0.0374968 0.119501" quat="0.499998 0.5 0.5 -0.500002"
              type="mesh" rgba="0.72549 0.45098 0.317647 1" mesh="link1" contype="0" conaffinity="0"/>

        <body name="link2" pos="-0.0329 0.02 0.0455" quat="0.499998 0.5 -0.500002 -0.5">
          <inertial pos="0.129165 0.000134495 -0.0321253"
                    quat="0.499976 0.500008 0.500105 0.499911"
                    mass="1.52608" diaginertia="0.0152377 0.0151654 0.000831129"/>
          <joint name="joint2" pos="0 0 0" axis="0 0 1" range="0 3.14159"/>
          <geom pos="-0.0174977 -0.0740001 -0.07925" quat="0.499998 0.5 0.500002 0.5"
                type="mesh" rgba="0 0.4 0.6 1" mesh="link2" contype="0" conaffinity="0"/>

          <body name="link3" pos="0.264 4.08431e-07 -0.06375" quat="9.38184e-07 -0.707105 -0.707108 9.38187e-07">
            <inertial pos="0.0556042 -0.135083 -0.0340514"
                      quat="0.704407 0.697077 0.121918 -0.0550519"
                      mass="0.982553" diaginertia="0.00765198 0.0076296 0.000876442"/>
            <joint name="joint3" pos="0 0 0" axis="0 0 1" range="0 3.66519"/>
            <geom pos="0.0740003 -0.281499 -0.0813" quat="9.38184e-07 9.38187e-07 0.707108 0.707105"
                  type="mesh" rgba="0.552941 0.580392 0.203922 1" mesh="link3" contype="0" conaffinity="0"/>

            <body name="link4" pos="0.0600003 -0.244999 -0.00205" quat="1.32679e-06 0 0 -1">
              <inertial pos="-0.0543529 0.057068 -0.0332231"
                        quat="0.636075 0.627088 0.370444 0.254833"
                        mass="0.46678" diaginertia="0.000817855 0.000791274 0.000295776"/>
              <joint name="joint4" pos="0 0 0" axis="0 0 1" range="-1.5708 1.5708"/>
              <geom pos="-0.0138003 0.0364989 -0.0787882" quat="0.707105 0.707108 0 0"
                    type="mesh" rgba="0.545098 0.52549 0.419608 1" mesh="link4" contype="0" conaffinity="0"/>

              <body name="link5" pos="-0.0403003 0.0703851 -0.0323887" quat="9.38184e-07 -0.707105 -9.38187e-07 -0.707108">
                <inertial pos="-3.55003e-05 -0.00717397 0.0375847"
                          quat="0.911516 0.411243 -0.00302177 -0.00303654"
                          mass="0.403307" diaginertia="0.000219794 0.000195686 0.000169647"/>
                <joint name="joint5" pos="0 0 0" axis="0 0 1" range="-1.5708 1.5708"/>
                <geom pos="-0.0463995 0.0311519 0.0265" quat="0.499998 -0.5 -0.5 -0.500002"
                      type="mesh" rgba="0.827451 0.623529 0.784314 1" mesh="link5" contype="0" conaffinity="0"/>

                <body name="gripper_body" pos="2.39858e-07 -0.0419481 0.0404996" quat="0.499998 -0.5 -0.5 -0.500002">
                  <inertial pos="-3.57066e-05 0.000249371 -0.0293133"
                            quat="0.667981 0.744113 -0.00433092 0.00882801"
                            mass="0.553219" diaginertia="0.000409686 0.000369758 0.000324415"/>
                  <joint name="joint6" pos="0 0 0" axis="0 0 1" range="-2.0944 2.0944"/>
                  <geom pos="-0.014 -0.0463995 0.0731" quat="1 0 0 0"
                        type="mesh" rgba="0.109804 0.286275 0.0117647 1" mesh="gripper_mesh" contype="0" conaffinity="0"/>

                  <!-- Gripper finger left -->
                  <body name="tip_left_body" pos="-0.0226681 0.0450619 -0.0545599" quat="0.499998 -0.5 -0.5 -0.500002">
                    <inertial pos="-0.0224716 0.0143408 -0.0426253"
                              quat="0.498899 0.455348 -0.0576406 0.735143"
                              mass="0.0710042" diaginertia="6.24193e-05 6.01079e-05 2.83591e-05"/>
                    <joint name="joint7" pos="0 0 0" axis="0 0 1" type="slide" range="-0.0475 0"/>
                    <geom pos="0.129783 0.00999321 -0.0914614" quat="0.499998 0.5 0.500002 0.5"
                          type="mesh" rgba="0.596078 0.788235 0.921569 1" mesh="tip_left" contype="0" conaffinity="0"/>
                  </body>

                  <!-- Gripper finger right -->
                  <body name="tip_right_body" pos="0.0226681 -0.0450619 -0.0545599" quat="0.707105 0.707108 0 0">
                    <inertial pos="-0.0143408 -0.0224716 -0.0426253"
                              quat="0.281222 0.8726 0.16705 -0.362738"
                              mass="0.0710042" diaginertia="6.24193e-05 6.01079e-05 2.83591e-05"/>
                    <joint name="joint8" pos="0 0 0" axis="0 0 1" type="slide" range="-0.0475 0"/>
                    <geom pos="-0.0379932 0.129783 0.00133753" quat="0.707105 -0.707108 0 0"
                          type="mesh" rgba="0.596078 0.788235 0.921569 1" mesh="tip_right" contype="0" conaffinity="0"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Actuators for joints 1-6 (arm) + coupled gripper -->
  <actuator>
    <position name="act_joint1" joint="joint1" kp="100"/>
    <position name="act_joint2" joint="joint2" kp="100"/>
    <position name="act_joint3" joint="joint3" kp="100"/>
    <position name="act_joint4" joint="joint4" kp="100"/>
    <position name="act_joint5" joint="joint5" kp="100"/>
    <position name="act_joint6" joint="joint6" kp="100"/>
    <position name="act_gripper_left"  joint="joint7" kp="50"/>
    <position name="act_gripper_right" joint="joint8" kp="50"/>
  </actuator>

  <!-- Equality constraint: couple gripper fingers (move together) -->
  <equality>
    <joint joint1="joint7" joint2="joint8" polycoef="0 1 0 0 0"/>
  </equality>

  <!-- Named camera for rendering -->
  <sensor/>

  <!-- Default camera for offscreen rendering -->
  <keyframe>
    <key name="home" qpos="0 1.57 1.57 0 0 0 -0.0475 -0.0475"/>
  </keyframe>
</mujoco>
